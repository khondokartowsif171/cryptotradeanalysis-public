{
  "name": "Crypto Price Alert",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 5
            }
          ]
        }
      },
      "id": "alert-schedule",
      "name": "Every 5 Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [0, 0]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.binance.com/api/v3/ticker/price?symbols=[\"BTCUSDT\",\"ETHUSDT\",\"SOLUSDT\"]",
        "sendHeaders": true,
        "options": {}
      },
      "id": "alert-fetch",
      "name": "Fetch Binance Prices",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [240, 0]
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{$json.price}}",
              "operation": "Smaller",
              "value2": 70000
            }
          ]
        },
        "combine": "ALL"
      },
      "id": "alert-check",
      "name": "Check BTC < $70K",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [480, 0]
    },
    {
      "parameters": {
        "collection": "alerts",
        "fields": {
          "values": {
            "string": [
              {"key": "symbol", "value": "={{$json.symbol}}"},
              {"key": "price", "value": "={{$json.price}}"},
              {"key": "type", "value": "BTC_THRESHOLD"},
              {"key": "threshold", "value": "70000"},
              {"key": "triggered_at", "value": "={{$now.toISOString()}}"}
            ]
          }
        }
      },
      "id": "alert-log",
      "name": "Log to MongoDB",
      "type": "n8n-nodes-base.mongoDb",
      "typeVersion": 2,
      "position": [720, -120]
    }
  ],
  "connections": {
    "Every 5 Minutes": {
      "main": [[{"node": "Fetch Binance Prices", "type": "main", "index": 0}]]
    },
    "Fetch Binance Prices": {
      "main": [[{"node": "Check BTC < $70K", "type": "main", "index": 0}]]
    },
    "Check BTC < $70K": {
      "main": [[{"node": "Log to MongoDB", "type": "main", "index": 0}]]
    }
  }
}
